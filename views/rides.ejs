<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Available Rides - BlaBla</title>
</head>
<body>
    
    <%- include('./navbar') %>

    <h1>Available Rides</h1>
    <p>Find your next journey below.</p>

    <% if (error) { %>
        <div style="color: red;"><strong>Error:</strong> <%= error %></div>
    <% } %>

    <% if (rides.length === 0) { %>
        <p>No rides available right now. Check back later!</p>
    <% } else { %>
        
        <div style="display: flex; flex-direction: column; gap: 15px;">
            <% rides.forEach(ride => { %>
                
                <div style="border: 1px solid #ccc; padding: 15px; border-radius: 8px; max-width: 500px;">
                    <div style="display: flex; align-items: center; margin-bottom: 10px;">
                        
                        <% if (ride.driver.profilePicture) { %>
                            <img src="<%= ride.driver.profilePicture %>" alt="Driver" style="width: 50px; height: 50px; border-radius: 50%; margin-right: 15px;">
                        <% } else { %>
                            <div style="width: 50px; height: 50px; border-radius: 50%; background-color: #eee; margin-right: 15px; display: flex; align-items: center; justify-content: center;">
                                👤
                            </div>
                        <% } %>
                        
                        <h3 style="margin: 0;"><%= ride.driver.name %></h3>
                    </div>

                    <p><strong>Route:</strong> <%= ride.source %> ➔ <%= ride.destination %></p>
                    <p>
                        <strong>Date:</strong> <%= ride.date.toDateString() %> | 
                        <strong>Time:</strong> <%= ride.departureTime %>
                    </p>
                    <p>
                        <strong>Price:</strong> ₹<%= ride.price %> | 
                        <strong>Seats Left:</strong> <%= ride.availableSeats %> / <%= ride.totalSeats %>
                    </p>
                    
                    <a href="/rides/<%= ride._id %>" style="display: inline-block; margin-top: 10px; padding: 5px 10px; background-color: #007bff; color: white; text-decoration: none; border-radius: 4px;">
                        View Details & Book
                    </a>
                </div>

            <% }) %>
        </div>

    <% } %>

</body>
</html>