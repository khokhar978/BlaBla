<%- include('../partials/header') %>

    <div class="container" style="display: flex; gap: 30px;">
        <div style="width: 30%; text-align: center;">
            <img src="<%= user.profilePic ? '/profilePictures/' + user.profilePic : '/profilePictures/avtar.webp' %>"
                alt="Profile"
                style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover; border: 3px solid #ccc;">
            <h2 style="margin-bottom: 5px;">
                <%= user.name %>
            </h2>
            <div style="display: flex; gap: 10px; justify-content: center; margin-top: 15px;">
                <a href="/profile/edit" class="btn" style="background: #20bf6b;">Edit</a>
                <a href="/auth/logout" class="btn" style="background: #ff4757;">Log Out</a>
            </div>
        </div>
        <div style="width: 70%;">
            <h3>About <%= user.name %>
            </h3>
            <p><strong>Email:</strong>
                <%= user.email %>
            </p>
            <p><strong>Phone:</strong>
                <%= user.phone || 'Not provided' %>
            </p>
            <p><strong>Bio:</strong>
                <%= user.bio || 'No bio yet.' %>
            </p>

            <hr style="margin: 30px 0;">

            <div style="display: flex; gap: 20px;">
                <a href="/rides/myRides" class="btn" style="background: #0088cc;">View My Rides</a>
                <a href="/bookings/my" class="btn" style="background: #20bf6b;">View My Bookings</a>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>