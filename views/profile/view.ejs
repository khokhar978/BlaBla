<%- include('../partials/header') %>

<div class="container" style="max-width: 800px; margin: 0 auto; padding: 20px;">
    <h2>Search Rides</h2>
    
    <!-- Search Form -->
    <form action="/rides/search" method="GET" style="display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 30px;">
        <input type="text" name="source" placeholder="Leaving from..." value="<%= locals.query?.source || '' %>" style="flex: 1; min-width: 200px; padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
        <input type="text" name="destination" placeholder="Going to..." value="<%= locals.query?.destination || '' %>" style="flex: 1; min-width: 200px; padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
        <input type="date" name="date" value="<%= locals.query?.date || '' %>" style="flex: 1; min-width: 150px; padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
        <input type="number" name="seats" placeholder="Seats" min="1" value="<%= locals.query?.seats || '' %>" style="width: 80px; padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
        <button type="submit" class="btn" style="height: 42px; background: #007bff; color: white; border: none; border-radius: 4px; padding: 0 20px; cursor: pointer;">Search</button>
    </form>

    <div class="rides-list">
        <% if (typeof rides !== 'undefined' && rides.length > 0) { %>
            <div style="display: flex; flex-direction: column; gap: 15px;">
                <% rides.forEach(ride => { %>   
                    <div class="ride-card" style="border: 1px solid #ccc; padding: 15px; border-radius: 8px; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 15px; align-items: center;">
                        
                        <div style="flex: 1; min-width: 250px;">       
                            <h3 style="margin: 0 0 10px 0;"><%= ride.source %> ➔ <%= ride.destination %></h3>
                            <p style="margin: 0; color: #555;">
                                <strong>Date:</strong> <%= new Date(ride.date).toLocaleDateString() %> | 
                                <strong>Time:</strong> <%= ride.departureTime %>
                            </p>
                            <p style="margin: 5px 0 0 0; color: #555;">
                                <strong>Driver:</strong> <%= ride.driver ? ride.driver.name : 'Unknown' %> | 
                                <strong>Seats Available:</strong> <%= ride.availableSeats %>
                            </p>
                        </div>

                        <div style="text-align: right; display: flex; flex-direction: column; align-items: flex-end;">
                            <h2 style="margin: 0 0 10px 0; color: #0088cc;">₹<%= ride.price %></h2>
                            <a href="/rides/<%= ride._id %>" class="btn" style="background: #20bf6b; color: white; padding: 10px 15px; text-decoration: none; border-radius: 4px;">View Map & Book</a>
                        </div>

                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div style="padding: 20px; border: 1px solid #ccc; border-radius: 8px; text-align: center;">
                <p style="font-size: 1.1em; color: #666;">No rides found matching your criteria. Try adjusting your search.</p>
            </div>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>