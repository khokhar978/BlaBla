<%- include('partials/header') %>

<div style="max-width: 400px; margin: 50px auto; background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); text-align: center;">
    <h2 style="color: #0088cc; margin-bottom: 10px;">Reset Password</h2>
    <p style="color: #777; margin-bottom: 20px; font-size: 0.9rem;">Enter your registered email address and we will send you an OTP to reset your password.</p>

    <% if (error) { %>
        <div style="color: #ff4757; background: #ffeaa7; padding: 10px; border-radius: 5px; margin-bottom: 15px;"><%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
        <div style="color: #155724; background: #d4edda; padding: 10px; border-radius: 5px; margin-bottom: 15px;"><%= success %></div>
    <% } %>

    <form action="/auth/forgot-password" method="POST" style="text-align: left;">
        <div style="margin-bottom: 20px;">
            <label for="email" style="font-weight: bold; color: #555;">Registered Email</label>
            <input type="email" id="email" name="email" required style="width: 100%; padding: 12px; margin-top: 5px; border: 1px solid #ccc; border-radius: 5px; font-size: 1rem;">
        </div>

        <button type="submit" class="btn" style="width: 100%; padding: 12px; font-size: 1.1rem; background: #0088cc; display: block; text-align: center;">Send OTP</button>
    </form>

    <div style="margin-top: 20px; font-size: 0.9rem;">
        <a href="/auth/login" style="color: #777; text-decoration: none;">&larr; Back to Login</a>
    </div>
</div>

<%- include('partials/footer') %>