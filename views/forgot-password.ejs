<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - BlaBla</title>
</head>
<body>
    <%- include('./navbar') %>

    <h1>Reset Your Password</h1>
    <p>Enter your registered email address and we will send you an OTP to reset your password.</p>

    <% if (error) { %>
        <div style="color: red;"><strong>Note:</strong> <%= error %></div>
    <% } %>

    <form action="/auth/forgot-password" method="POST">
        <div style="margin-bottom: 10px;">
            <label for="email">Registered Email:</label><br>
            <input type="email" id="email" name="email" required>
        </div>

        <button type="submit">Send OTP</button>
    </form>

    <br>
    <a href="/auth/login">Back to Login</a>

</body>
</html>