<%- include('partials/header') %>

<div style="max-width: 400px; margin: 50px auto; background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); text-align: center;">
    <h2 style="color: #0088cc; margin-bottom: 10px;">Verify Your Account</h2>
    <p style="color: #777; margin-bottom: 20px;">Please enter the 4-digit code sent to your email.</p>

    <% if (error) { %>
        <div style="color: #ff4757; background: #ffeaa7; padding: 10px; border-radius: 5px; margin-bottom: 15px;"><%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
        <div style="color: #155724; background: #d4edda; padding: 10px; border-radius: 5px; margin-bottom: 15px;"><%= success %></div>
    <% } %>

    <form action="/auth/verify" method="POST" style="text-align: left;">
        <input type="hidden" name="email" value="<%= email %>">
        
        <div style="margin-bottom: 20px;">
            <label for="otp" style="font-weight: bold; color: #555;">One-Time Password (OTP)</label>
            <input type="text" id="otp" name="otp" required maxlength="4" pattern="\d{4}" style="width: 100%; padding: 15px; margin-top: 5px; border: 1px solid #ccc; border-radius: 5px; font-size: 1.5rem; text-align: center; letter-spacing: 5px;">
        </div>

        <button type="submit" class="btn" style="width: 100%; padding: 12px; font-size: 1.1rem; background: #0088cc; display: block; text-align: center;">Verify Account</button>
    </form>

    <div style="margin-top: 25px; padding-top: 20px; border-top: 1px solid #eee;">
        <form action="/auth/resend-otp" method="POST">
            <input type="hidden" name="email" value="<%= email %>">
            <p style="margin-bottom: 10px; color: #777; font-size: 0.9rem;">Didn't receive the code or it expired?</p>
            <button type="submit" class="btn" style="background: #eaebed; color: #333; width: 100%;">Resend OTP</button>
        </form>
    </div>
</div>

<%- include('partials/footer') %>