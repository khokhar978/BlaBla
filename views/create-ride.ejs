<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Publish a Ride - BlaBla</title>
</head>
<body>
    
    <%- include('./navbar') %>

    <h1>Publish a New Ride</h1>
    <p>Offer a ride to passengers and share your travel costs.</p>

    <% if (typeof error !== 'undefined' && error) { %>
        <div style="color: red;"><strong>Error:</strong> <%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
        <div style="color: green;"><strong>Success:</strong> <%= success %></div>
    <% } %>

    <form action="/rides/create" method="POST">
        
        <h3>Route Details</h3>
        <div style="margin-bottom: 10px;">
            <label for="source">Source City:</label><br>
            <input type="text" id="source" name="source" required placeholder="e.g., Panchkula">
        </div>

        <div style="margin-bottom: 15px;">
            <label for="destination">Destination City:</label><br>
            <input type="text" id="destination" name="destination" required placeholder="e.g., Chandigarh">
        </div>

        <h3>Trip Schedule & Seats</h3>
        <div style="margin-bottom: 10px;">
            <label for="date">Date of Journey:</label><br>
            <input type="date" id="date" name="date" required>
        </div>

        <div style="margin-bottom: 10px;">
            <label for="departureTime">Departure Time:</label><br>
            <input type="time" id="departureTime" name="departureTime" required>
        </div>

        <div style="margin-bottom: 10px;">
            <label for="price">Price per Seat (₹):</label><br>
            <input type="number" id="price" name="price" min="0" required>
        </div>

        <div style="margin-bottom: 15px;">
            <label for="totalSeats">Total Seats Available:</label><br>
            <input type="number" id="totalSeats" name="totalSeats" min="1" max="8" required>
        </div>

        <!-- <hr>
        <h3>Map Coordinates (Temporary for Testing)</h3>
        <p><em>Just enter dummy numbers like 30.69 and 76.86 for now.</em></p>
         -->
        <!-- <div style="margin-bottom: 10px;">
            <label>Source Coordinates (Lat / Lng):</label><br>
            <input type="number" step="any" name="sourceLat" required placeholder="Latitude">
            <input type="number" step="any" name="sourceLng" required placeholder="Longitude">
        </div>

        <div style="margin-bottom: 15px;">
            <label>Destination Coordinates (Lat / Lng):</label><br>
            <input type="number" step="any" name="destLat" required placeholder="Latitude">
            <input type="number" step="any" name="destLng" required placeholder="Longitude">
        </div> -->

        <button type="submit">Publish Ride</button>
    </form>

</body>
</html>