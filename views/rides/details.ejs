<%- include('../partials/header') %>

<div class="container" style="display: flex; gap: 30px; flex-wrap: wrap; padding: 20px;">
    <!-- Ride Information -->
    <div style="flex: 1; min-width: 300px;">
        <h2>Ride Details</h2>
        <div class="ride-card" style="display: block; border: 1px solid #ccc; padding: 20px; border-radius: 8px;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <h3 style="margin: 0;"><%= ride.source %> ➔ <%= ride.destination %></h3>
                <h3 style="color: #0088cc; margin: 0;">₹<%= ride.price %></h3>
            </div>
            
            <hr style="margin: 15px 0;">
            
            <div style="display: flex; justify-content: space-between; margin-top: 15px;">
                <div>
                    <p style="margin: 5px 0;"><strong>Departure Date:</strong> <%= new Date(ride.date).toLocaleDateString() %></p>
                    <p style="margin: 5px 0;"><strong>Time:</strong> <%= ride.departureTime %></p>
                    <p style="margin: 5px 0;"><strong>Available Seats:</strong> <%= ride.availableSeats %> / <%= ride.totalSeats %></p>
                </div>
                <!-- Driver Info -->
                <div style="text-align: center;">
                    <% if (ride.driver.profilePicture) { %>
                        <img src="<%= ride.driver.profilePicture %>" alt="Driver" style="width: 60px; height: 60px; border-radius: 50%; object-fit: cover;">
                    <% } else { %>
                        <div style="width: 60px; height: 60px; border-radius: 50%; background-color: #eee; margin: 0 auto; display: flex; align-items: center; justify-content: center; font-size: 24px;">👤</div>
                    <% } %>
                    <p style="margin: 5px 0 0 0;"><strong><%= ride.driver.name %></strong></p>
                    <p style="font-size: 0.9em; color: #666; width: 150px; text-wrap: wrap;"><%= ride.driver.bio || 'Verified Driver' %></p>
                </div>
            </div>

            <hr style="margin: 15px 0;">

            <% if (user && user.userId !== ride.driver._id.toString() && ride.availableSeats > 0 && ride.status !== 'cancelled') { %>
                <form id="bookForm" style="margin-top: 15px;">
                    <input type="hidden" name="rideId" value="<%= ride._id %>">
                    <input type="hidden" name="seatsBooked" id="seatsBookedInput" value="1"> <!-- Added for backend compatibility -->
                    
                    <label>Seats to book:</label>
                    <select name="seats" style="width: auto; display: inline-block; padding: 5px;" onchange="document.getElementById('seatsBookedInput').value = this.value">
                        <% for(let i=1; i<=ride.availableSeats; i++) { %>
                            <option value="<%= i %>"><%= i %></option>
                        <% } %>
                    </select>
                    
                    <label style="margin-left: 15px;">Payment:</label>
                    <select name="paymentMethod" style="width: auto; display: inline-block; padding: 5px;">
                        <option value="cash">Cash on ride</option>
                        <option value="online">Online Payment</option>
                    </select>
                    
                    <button class="btn" style="float: right; margin-top: 5px; background: #28a745; color: white; padding: 8px 15px; border: none; border-radius: 4px; cursor: pointer;">Book Now</button>
                </form>
                <div style="clear: both;"></div>
                <p class="error" style="color: red; margin-top: 10px; font-weight: bold;"></p>
            <% } else if (!user) { %>
                <p>Please <a href="/auth/login" style="color: #0088cc;">log in</a> to book this ride.</p>
            <% } else if (ride.status === 'cancelled') { %>
                <p style="color: red; font-weight: bold; text-align: center;">This ride has been cancelled by the driver.</p>
            <% } else if (ride.availableSeats === 0) { %>
                <p style="color: orange; font-weight: bold; text-align: center;">This ride is fully booked.</p>
            <% } else { %>
                <p style="text-align: center; font-style: italic; color: #666;">This is your published ride.</p>
            <% } %>

            <% if (user) { %>
                <div style="margin-top: 20px; text-align: center;">
                    <a href="/chat/<%= ride._id %>" class="btn" style="background: #e1b12c; color: white; padding: 10px 20px; text-decoration: none; border-radius: 4px; display: inline-block;">Open Live Chat</a>
                </div>
            <% } %>
        </div>
    </div>
    
    <!-- Map Integration -->
    <div style="flex: 1; min-width: 300px;">
        <h3>Route Map</h3>
        <!-- CRITICAL: The map div MUST have a height or it won't render -->
        <div id="map" class="map-container" style="height: 400px; width: 100%; border-radius: 8px; border: 1px solid #ccc; z-index: 1;"></div>
    </div>
</div>

<!-- Base Leaflet CSS and JS (Required for the map to work) -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<!-- Leaflet Routing Machine CSS and JS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.css" />
<script src="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.js"></script>

<script>
    // Leaflet Map Initialization
    window.addEventListener("load", () => {
        const sourceLat = <%= ride.sourceCoords?.lat || 30.7333 %>;
        const sourceLng = <%= ride.sourceCoords?.lng || 76.7794 %>;
        const destLat = <%= ride.destinationCoords?.lat || 28.7041 %>;
        const destLng = <%= ride.destinationCoords?.lng || 77.1025 %>;

        const map = L.map('map').setView([sourceLat, sourceLng], 5);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        L.Routing.control({
            waypoints: [
                L.latLng(sourceLat, sourceLng),
                L.latLng(destLat, destLng)
            ],
            routeWhileDragging: false,
            addWaypoints: false,
            draggableWaypoints: false,
            fitSelectedRoutes: true,
            showAlternatives: false,
            lineOptions: {
                styles: [{color: '#ff4757', weight: 4}]
            },
            createMarker: function(i, wp, nWps) {
                if (i === 0) {
                    return L.marker(wp.latLng).bindPopup('Departure: <%= ride.source %>').openPopup();
                } else if (i === nWps - 1) {
                    return L.marker(wp.latLng).bindPopup('Destination: <%= ride.destination %>');
                }
            }
        }).addTo(map);
    });

    // Booking Submission
    const form = document.getElementById('bookForm');
    if (form) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const errorElem = document.querySelector('.error');
            const submitBtn = form.querySelector('button');
            errorElem.textContent = '';
            
            const originalText = submitBtn.textContent;
            submitBtn.textContent = "Booking...";
            submitBtn.disabled = true;

            const formData = new FormData(form);
            const dataObj = Object.fromEntries(formData.entries());

            try {
                // Pointed this to the route we established earlier
                const res = await fetch(`/bookings/create/${dataObj.rideId}`, {
                    method: 'POST',
                    body: JSON.stringify(dataObj),
                    headers: { 'Content-Type': 'application/json' }
                });
                
                if (res.ok) {
                    // Success! Redirect to the user's bookings page
                    window.location.assign('/bookings/my');
                } else {
                    const textError = await res.text();
                    errorElem.textContent = textError || "Booking failed.";
                    submitBtn.textContent = originalText;
                    submitBtn.disabled = false;
                }
            } catch (err) {
                console.log(err);
                errorElem.textContent = "A network error occurred.";
                submitBtn.textContent = originalText;
                submitBtn.disabled = false;
            }
        });
    }
</script>

<%- include('../partials/footer') %>