<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BlaBla Carpooling App</title>

    <style>

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            background-color: #f4f7f6;
            color: #333;
        }

        header {
            background: #0088cc;
            color: white;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        header a {
            color: white;
            text-decoration: none;
            margin: 0 10px;
            font-weight: bold;
        }

        .btn {
            background: #ff4757;
            color: white;
            padding: 8px 15px;
            border-radius: 5px;
            text-decoration: none;
            display: inline-block;
            cursor: pointer;
            border: none;
        }

        .btn:hover {
            background: #ff6b81;
        }

        .container {
            max-width: 1000px;
            margin: 20px auto;
            padding: 20px;
            background: white;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        input,
        select {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
            border: 1px solid #ccc;
            border-radius: 5px;
            box-sizing: border-box;
        }

        .nav-links {
            display: flex;
            align-items: center;
        }

        .profile-pic-small {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            object-fit: cover;
            margin-left: 10px;
        }


        .ride-card {
            border: 1px solid #ddd;
            padding: 15px;
            margin-bottom: 15px;
            border-radius: 5px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .map-container {
            height: 300px;
            width: 100%;
            margin-top: 15px;
            border-radius: 5px;
            background: #eaebed;
        }

        /* chat stuff */
        .chat-container {
            height: 400px;
            border: 1px solid #ccc;
            border-radius: 5px;
            display: flex;
            flex-direction: column;
        }

        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 15px;
            background: #fafafa;
        }

        .chat-input {
            display: flex;
            border-top: 1px solid #ccc;
        }

        .chat-input input {
            border: none;
            flex: 1;
            margin: 0;
            border-radius: 0 0 0 5px;
        }

        .chat-input button {
            border-radius: 0 0 5px 0;
            margin: 0;
        }

        .message {
            margin-bottom: 15px;
        }

        .message strong {
            color: #0088cc;
        }
    </style>
</head>

<body>
    <header>
        <div class="logo">
            <a href="/" style="font-size: 1.5rem;">🚗 BlaBla Carpool</a>
        </div>
        <div class="nav-links">
            <a href="/rides/search">Find a Ride</a>
            <% if (locals.user) { %>
                <a href="/rides/create">Publish Ride</a>
                <a href="/rides/myRides">My Rides</a>
                <a href="/bookings/my">My Bookings</a>
                <a href="/profile" style="display: flex; align-items: center; gap: 8px;">
                    <span style="font-weight: 500;"><%= locals.user.name %></span>
                    <img src="<%= locals.user.profilePic ? '/profilePictures/'+locals.user.profilePic : '/profilePictures/avtar.webp' %>"
                         alt="Profile" class="profile-pic-small" style="margin: 0;">
                </a>
                <a href="/auth/logout" class="btn">Logout</a>
                <% } else { %>
                    <a href="/auth/login">Login</a>
                    <a href="/auth/signup" class="btn">Sign Up</a>
                    <% } %>
        </div>
    </header>
    <main class="container">