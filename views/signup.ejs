<%- include('partials/header') %>

<div style="max-width: 450px; margin: 50px auto; background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); text-align: center;">
    <h2 style="color: #0088cc; margin-bottom: 20px;">Create an Account</h2>

    <% if (error) { %>
        <div style="color: #ff4757; background: #ffeaa7; padding: 10px; border-radius: 5px; margin-bottom: 15px;"><%= error %></div>
    <% } %>

    <form action="/auth/signup" method="POST" style="text-align: left;">
        
        <div style="margin-bottom: 15px;">
            <label for="name" style="font-weight: bold; color: #555;">Full Name</label>
            <input type="text" id="name" name="name" required style="width: 100%; padding: 12px; margin-top: 5px; border: 1px solid #ccc; border-radius: 5px; font-size: 1rem;">
        </div>

        <div style="margin-bottom: 15px;">
            <label for="email" style="font-weight: bold; color: #555;">Email</label>
            <input type="email" id="email" name="email" required style="width: 100%; padding: 12px; margin-top: 5px; border: 1px solid #ccc; border-radius: 5px; font-size: 1rem;">
        </div>

        <div style="margin-bottom: 15px;">
            <label for="password" style="font-weight: bold; color: #555;">Password</label>
            <input type="password" id="password" name="password" required style="width: 100%; padding: 12px; margin-top: 5px; border: 1px solid #ccc; border-radius: 5px; font-size: 1rem;">
        </div>

        <div style="margin-bottom: 25px;">
            <label for="confirmPassword" style="font-weight: bold; color: #555;">Confirm Password</label>
            <input type="password" id="confirmPassword" name="confirmPassword" required style="width: 100%; padding: 12px; margin-top: 5px; border: 1px solid #ccc; border-radius: 5px; font-size: 1rem;">
        </div>

        <button type="submit" class="btn" style="width: 100%; padding: 12px; font-size: 1.1rem; background: #0088cc; display: block; text-align: center;">Sign Up</button>
    </form>

    <div style="margin-top: 20px; font-size: 0.9rem;">
        <span style="color: #777;">Already have an account?</span> <a href="/auth/login" style="color: #ff4757; font-weight: bold; text-decoration: none;">Log in here</a>
    </div>
</div>

<%- include('partials/footer') %>