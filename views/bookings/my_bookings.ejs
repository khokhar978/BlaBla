<%- include('../partials/header') %>

<div class="container" style="max-width: 900px; margin: 0 auto; padding: 20px;">
    <h2>My Bookings</h2>
    <p>Your upcoming and past trips.</p>

    <% if (bookings.length > 0) { %>
        <div style="display: flex; flex-direction: column; gap: 20px;">
            <% bookings.forEach(b => { %>
                
                <div class="ride-card" style="border: 1px solid #ccc; padding: 15px; border-radius: 8px; display: flex; flex-wrap: wrap; gap: 15px; align-items: center;">
                    
                    <!-- Safety check in case the ride was completely deleted -->
                    <% if (b.ride) { %>
                        
                        <!-- Route & Booking Info -->
                        <div style="flex: 2; min-width: 250px;">
                            <h3 style="margin-top: 0; margin-bottom: 10px;"><%= b.ride.source %> ➔ <%= b.ride.destination %></h3>
                            <p style="margin: 5px 0;"><strong>Date:</strong> <%= new Date(b.ride.date).toLocaleDateString() %> at <%= b.ride.departureTime %></p>
                            <p style="margin: 5px 0;"><strong>Seats Booked:</strong> <%= b.seatsBooked %></p>
                            <p style="margin: 5px 0;">
                                <strong>Booking Status:</strong> 
                                <span style="color: <%= b.status === 'cancelled' ? 'red' : (b.status === 'confirmed' ? 'green' : '#ff9800') %>; font-weight: bold;">
                                    <%= b.status.toUpperCase() %>
                                </span>
                            </p>
                            <!-- Adjusted to match your Boolean paymentStatus from the schema -->
                            <p style="margin: 5px 0;"><strong>Payment:</strong> <%= b.paymentStatus ? 'Paid Online' : 'Pending (Cash on Ride)' %></p>
                        </div>
                        
                        <!-- Driver Info -->
                        <div style="flex: 1; min-width: 150px; text-align: center; border-left: 1px solid #eee; border-right: 1px solid #eee; padding: 0 15px;">
                            <h4 style="margin-top: 0; margin-bottom: 10px; color: #666;">Driver</h4>
                            
                            <% if (b.driver && b.driver.profilePic) { %>
                                <img src="<%='/profilePictures/'+user.profilePic%>"  alt="Driver" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover;">
                            <% } else { %>
                                <div style="width: 50px; height: 50px; border-radius: 50%; background-color: #eee; margin: 0 auto; display: flex; align-items: center; justify-content: center; font-size: 20px;">👤</div>
                            <% } %>
                            
                            <p style="margin: 5px 0 0 0;"><strong><%= b.driver ? b.driver.name : 'Unknown' %></strong></p>
                            
                            <div style="margin-top: 15px;">
                                <a href="/rides/<%= b.ride._id %>" class="btn" style="background: #0088cc; color: white; padding: 6px 12px; text-decoration: none; border-radius: 4px; font-size: 0.9em; display: inline-block;">View Ride Details</a>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div style="flex: 1; min-width: 150px; text-align: right;">
                            <% if (b.status !== 'cancelled' && b.ride.status !== 'cancelled') { %>
                                <form action="/bookings/cancel/<%= b._id %>" method="POST" style="margin: 0;">
                                    <button type="submit" class="btn" style="background: #ff4757; color: white; padding: 8px 15px; border: none; border-radius: 4px; cursor: pointer; width: 100%;" onclick="return confirm('Are you sure you want to cancel this booking?');">Cancel Booking</button>
                                </form>
                            <% } else if (b.ride.status === 'cancelled') { %>
                                <p style="color: red; font-weight: bold; margin: 0;">Ride Cancelled by Driver</p>
                            <% } else if (b.status === 'cancelled') { %>
                                <p style="color: red; font-weight: bold; margin: 0;">You Cancelled</p>
                            <% } %>
                        </div>
                        
                    <% } else { %>
                        <div style="flex: 1; padding: 10px;">
                            <p style="color: red; margin: 0;"><strong>Error:</strong> This ride was deleted from the system.</p>
                        </div>
                    <% } %>

                </div>

            <% }) %>
        </div>
    <% } else { %>
        <div style="padding: 30px; border: 1px solid #ccc; border-radius: 8px; text-align: center;">
            <p style="font-size: 1.1em;">You have no bookings right now.</p>
            <br>
            <a href="/rides" class="btn" style="background: #007bff; color: white; padding: 10px 20px; text-decoration: none; border-radius: 4px;">Find a Ride Now</a>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>