<%- include('partials/header') %>

<div style="max-width: 400px; margin: 50px auto; background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); text-align: center;">
    <h2 style="color: #0088cc; margin-bottom: 20px;">Log In to BlaBla</h2>

    <% if (error) { %>
        <div style="color: #ff4757; background: #ffeaa7; padding: 10px; border-radius: 5px; margin-bottom: 15px;"><%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
        <div style="color: #155724; background: #d4edda; padding: 10px; border-radius: 5px; margin-bottom: 15px;"><%= success %></div>
    <% } %>

    <form action="/auth/login" method="POST" style="text-align: left;">
        <div style="margin-bottom: 15px;">
            <label for="email" style="font-weight: bold; color: #555;">Email</label>
            <input type="email" id="email" name="email" value="<%= typeof data !== 'undefined' && data ? data.email : '' %>" required style="width: 100%; padding: 12px; margin-top: 5px; border: 1px solid #ccc; border-radius: 5px; font-size: 1rem;">
        </div>

        <div style="margin-bottom: 20px;">
            <label for="password" style="font-weight: bold; color: #555;">Password</label>
            <input type="password" id="password" name="password" required style="width: 100%; padding: 12px; margin-top: 5px; border: 1px solid #ccc; border-radius: 5px; font-size: 1rem;">
        </div>

        <button type="submit" class="btn" style="width: 100%; padding: 12px; font-size: 1.1rem; background: #0088cc; display: block; text-align: center;">Log In</button>
    </form>

    <div style="margin-top: 20px; font-size: 0.9rem;">
        <a href="/auth/forgot-password" style="color: #0088cc; text-decoration: none;">Forgot Password?</a>
        <br><br>
        <span style="color: #777;">Don't have an account?</span> <a href="/auth/signup" style="color: #ff4757; font-weight: bold; text-decoration: none;">Sign up here</a>
    </div>
</div>

<%- include('partials/footer') %>