<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ride Details - BlaBla</title>
</head>
<body>
    <%- include('./navbar') %>

    <h1>Trip to <%= ride.destination %></h1>
    
    <% if (error) { %>
        <div style="color: red;"><strong>Error:</strong> <%= error %></div>
    <% } %>

    <div style="border: 1px solid #ccc; padding: 15px; border-radius: 8px; max-width: 500px;">
        <p><strong>Driver:</strong> <%= ride.driver.name %></p>
        <p><strong>Route:</strong> <%= ride.source %> ➔ <%= ride.destination %></p>
        <p><strong>Departure:</strong> <%= ride.date.toDateString() %> at <%= ride.departureTime %></p>
        <p><strong>Price per seat:</strong> ₹<%= ride.price %></p>
        <p><strong>Seats Available:</strong> <%= ride.availableSeats %></p>
        
        <hr>

        <form action="/bookings/create/<%= ride._id %>" method="POST">
            <label for="seatsBooked">How many seats?</label>
            <input type="number" id="seatsBooked" name="seatsBooked" min="1" max="<%= ride.availableSeats %>" required>
            <br><br>
            <button type="submit">Confirm Booking</button>
        </form>
    </div>

</body>
</html>