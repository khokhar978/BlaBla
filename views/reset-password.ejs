<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Set New Password - BlaBla</title>
</head>
<body>
    <%- include('./navbar') %>

    <h1>Create New Password</h1>

    <% if (error) { %>
        <div style="color: red;"><strong>Error:</strong> <%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
        <div style="color: green;"><strong>Success:</strong> <%= success %></div>
    <% } %>

    <form action="/auth/reset-password" method="POST">
        <input type="hidden" name="email" value="<%= email %>">

        <div style="margin-bottom: 10px;">
            <label for="otp">Enter 4-digit OTP:</label><br>
            <input type="text" id="otp" name="otp" required maxlength="4" pattern="\d{4}">
        </div>

        <div style="margin-bottom: 10px;">
            <label for="newPassword">New Password:</label><br>
            <input type="password" id="newPassword" name="newPassword" required>
        </div>

        <div style="margin-bottom: 15px;">
            <label for="confirmNewPassword">Confirm New Password:</label><br>
            <input type="password" id="confirmNewPassword" name="confirmNewPassword" required>
        </div>

        <button type="submit">Update Password</button>
    </form>

</body>
</html>